{
  "ReleaseInfo": {
    "Version": "v0.0.0-dev",
    "Codename": "LocalDevelopment"
  },
  "Logging":  {
    "LogLevel":  {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "ProjectK.API": "Information"
    }
  },

  "AllowedHosts":  "*",

  "ConnectionStrings":  {
    "DefaultConnection":  "",
    "BlobStorage":  ""
  },

  "BlobStorage":  {
    "ContainerName":  "photos",
    "PublicAccess":  true,
    "BlobPrefix":  "photos",
    "PublicBaseUrl":  ""
  },

  "OrphanCleanup":  {
    "Enabled":  true,
    "Interval":  "06:00:00",
    "GracePeriod":  "01:00:00",
    "MaxDeletesPerRun":  500,
    "DryRun":  false,
    "JitterSeconds":  30
  },

  "Jwt":  {
    "Key":  "",
    "Issuer":  "ProjectK-Backend",
    "Audience":  "ProjectK-Users",
    "ExpiresInMinutes":  10,
    "RefreshTokenExpiresInDays": 7
  },

  "DebugMode":  {
    "SecurePasswordOptions":  true
  },

  "ProbeAndBadges":  {
    "DataSource":  "Auto",
    "EnableAssetsExtraction":  true,
    "EnableLocalReleaseZipCache":  true,
    "EnableLatestReleaseEtagCache":  true,
    "AutoFallbackToEmbeddedSeed":  true,
    "VerifyReleaseZipChecksum":  true,
    "RequireReleaseZipChecksumAsset":  false,
    "RemoteRequestTimeoutSeconds":  30
  },
  "SecurityPatch":  {
    "EnableResourceGuard":  true
  },

  "Onboarding": {
    "IsClosedBeta": true,
    "GlobalBetaCap": 10
  },

  "EnvCorsOrigin": "https://projectk.rostyslav-mukha.dev",

  "Email":  {
    "FromEmail":  "projectk-system@mail-noreply.rostyslav-mukha.dev",
    "ApiKey":  "",
    "Provider":  "Resend",
    "BaseUrl":  "https://projectk.rostyslav-mukha.dev",
    "FromName":  "ProjectK"
  }
}
