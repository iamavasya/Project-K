{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=projectK;Trusted_Connection=True;TrustServerCertificate=True;",
    "BlobStorage": "UseDevelopmentStorage=true"
  },

  "BlobStorage": {
    "ContainerName": "photos",
    "PublicAccess": true,
    "BlobPrefix": "photos",
    "PublicBaseUrl": "http://127.0.0.1:10000/devstoreaccount1/photos"
  },

  "OrphanCleanup": {
    "Enabled": true,
    "Interval": "06:00:00",
    "GracePeriod": "01:00:00",
    "MaxDeletesPerRun": 500,
    "DryRun": false,
    "JitterSeconds": 30
  },

  "Jwt": {
    "Key": "local-env-jwt-key-11092025-EXTRACHARS",
    "Issuer": "ProjectK-Backend",
    "Audience": "ProjectK-Users",
    "ExpiresInMinutes": 10
  },

  "DebugMode": {
    "SecurePasswordOptions": true
  }
}