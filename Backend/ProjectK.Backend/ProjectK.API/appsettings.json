{
  "ReleaseInfo": {
    "Version": "v0.0.0-dev",
    "Codename": "LocalDevelopment"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/audit-.log",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  
  "Jwt": {
    "Key": "",
    "Issuer": "",
    "Audience": "",
    "ExpiresInMinutes": 0,
    "RefreshTokenExpiresInDays": 7
  },

  "ProbeAndBadges": {
    "DataSource": "Auto",
    "EnableAssetsExtraction": true,
    "EnableLocalReleaseZipCache": true,
    "EnableLatestReleaseEtagCache": true,
    "AutoFallbackToEmbeddedSeed": true,
    "VerifyReleaseZipChecksum": true,
    "RequireReleaseZipChecksumAsset": false,
    "RemoteRequestTimeoutSeconds": 30
  },

  "SecurityPatch": {
    "EnableResourceGuard": true,
    "EnableGeoBlocking": true,
    "BlockedCountries": [ "RU", "BY" ]
  },

  "LoadTestApiKey": "",

  "Onboarding": {
    "IsClosedBeta": true,
    "GlobalBetaCap": 10
  },

  "EnvCorsOrigin": "",

  "Email": {
    "Provider": "Mock",
    "ApiKey": "re_...",
    "FromEmail": "onboarding@resend.dev",
    "FromName": "ProjectK",
    "BaseUrl": "http://localhost:4200"
  }
}
