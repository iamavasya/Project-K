{
  "ReleaseInfo": {
    "Version": "v0.0.0-dev",
    "Codename": "LocalDevelopment"
  },
  
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.ApplicationInsights",
      "Serilog.Sinks.Telegram",
      "Serilog.Filters.Expressions"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "Logger",
        "Args": {
          "configureLogger": {
            "Filter": [
              {
                "Name": "ByIncludingOnly",
                "Args": {
                  "expression": "EventType = 'Security.Suspicious'"
                }
              }
            ],
            "WriteTo": [
              {
                "Name": "Telegram",
                "Args": {
                  "botToken": "YOUR_TELEGRAM_BOT_TOKEN_HERE",
                  "chatId": "YOUR_TELEGRAM_CHAT_ID_HERE",
                  "restrictedToMinimumLevel": "Warning",
                  "outputTemplate": "🚨 *ProjectK Alert* 🚨\n*Environment:* {ReleaseInfo:Codename}\n*Level:* {Level:u3}\n*Time:* {Timestamp:yyyy-MM-dd HH:mm:ss}\n*Message:* {Message:lj}\n*Exception:* {Exception}"
                }
              }
            ]
          }
        }
      },
      {
        "Name": "ApplicationInsights",
        "Args": {
          "connectionString": "InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://local.in.applicationinsights.azure.com/;LiveEndpoint=https://local.livediagnostics.monitor.azure.com/",
          "telemetryConverter": "Serilog.Sinks.ApplicationInsights.TelemetryConverters.TraceTelemetryConverter, Serilog.Sinks.ApplicationInsights"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  
  "Jwt": {
    "Key": "",
    "Issuer": "",
    "Audience": "",
    "ExpiresInMinutes": 0,
    "RefreshTokenExpiresInDays": 7
  },

  "ProbeAndBadges": {
    "DataSource": "Auto",
    "EnableAssetsExtraction": true,
    "EnableLocalReleaseZipCache": true,
    "EnableLatestReleaseEtagCache": true,
    "AutoFallbackToEmbeddedSeed": true,
    "VerifyReleaseZipChecksum": true,
    "RequireReleaseZipChecksumAsset": false,
    "RemoteRequestTimeoutSeconds": 30
  },

  "SecurityPatch": {
    "EnableResourceGuard": true,
    "EnableGeoBlocking": true,
    "BlockedCountries": [ "RU", "BY" ]
  },

  "SecurityMonitoring": {
    "FailedLoginThreshold": 5,
    "FailedMfaThreshold": 5,
    "FailedLoginWindow": "00:10:00",
    "FailedMfaWindow": "00:10:00",
    "IpChangeWindow": "1.00:00:00"
  },

  "LoadTestApiKey": "",

  "Onboarding": {
    "IsClosedBeta": true,
    "GlobalBetaCap": 10
  },

  "EnvCorsOrigin": "",

  "Email": {
    "Provider": "Mock",
    "ApiKey": "re_...",
    "FromEmail": "onboarding@resend.dev",
    "FromName": "ProjectK",
    "BaseUrl": "http://localhost:4200"
  }
}
