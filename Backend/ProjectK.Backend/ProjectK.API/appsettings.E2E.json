{
  "ReleaseInfo": {
    "Version": "v0.0.0-e2e",
    "Codename": "E2E"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "RateLimitBypassKey": "e2e-bypass-key",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=projectK_e2e;Trusted_Connection=True;TrustServerCertificate=True;",
    "BlobStorage": "UseDevelopmentStorage=true"
  },
  "BlobStorage": {
    "ContainerName": "photos-e2e",
    "PublicAccess": true,
    "BlobPrefix": "photos-e2e",
    "PublicBaseUrl": "http://127.0.0.1:10000/devstoreaccount1/photos-e2e"
  },
  "OrphanCleanup": {
    "Enabled": false
  },
  "Jwt": {
    "Key": "local-e2e-jwt-key-11092025-EXTRACHARS",
    "Issuer": "ProjectK-Backend",
    "Audience": "ProjectK-Users",
    "ExpiresInMinutes": 120,
    "RefreshTokenExpiresInDays": 7
  },
  "AdminServiceToken": {
    "PublicAnnouncementDraft": ""
  },
  "DebugMode": {
    "SecurePasswordOptions": true
  },
  "ProbeAndBadges": {
    "DataSource": "Auto",
    "EnableAssetsExtraction": true,
    "EnableLocalReleaseZipCache": true,
    "EnableLatestReleaseEtagCache": true,
    "AutoFallbackToEmbeddedSeed": true,
    "VerifyReleaseZipChecksum": true,
    "RequireReleaseZipChecksumAsset": false,
    "RemoteRequestTimeoutSeconds": 30
  },
  "SecurityPatch": {
    "EnableResourceGuard": true
  },
  "EnvCorsOrigin": "http://localhost:4200",
  "E2E": {
    "ResetToken": "local-e2e-reset-token",
    "BypassPrivilegedMfa": true
  },
  "Telegram": {
    "PublicChannel": {
      "Enabled": true,
      "DryRun": true,
      "BotToken": "",
      "ChatId": "",
      "BaseUrl": "https://api.telegram.org",
      "TimeoutSeconds": 10,
      "DisableNotification": false
    }
  },
  "Email": {
    "FromEmail": "projectk-system@mail-noreply.rostyslav-mukha.dev",
    "ApiKey": "re_api_key",
    "Provider": "Mock",
    "BaseUrl": "http://127.0.0.1:4200",
    "BetaCap": 10,
    "FromName": "ProjectK-E2E"
  }
}
