PROJECTK_VERSION=0.14.1-beta

PROJECTK_PUBLIC_URL=http://localhost:8080
PROJECTK_API_URL=http://localhost:5205/api
PROJECTK_CORS_ORIGIN=http://localhost:8080

PROJECTK_WEB_PORT=8080
PROJECTK_API_PORT=5205
PROJECTK_SQL_PORT=1433
PROJECTK_AZURITE_BLOB_PORT=10000
PROJECTK_AZURITE_QUEUE_PORT=10001
PROJECTK_AZURITE_TABLE_PORT=10002

# Change before exposing the instance outside your machine.
PROJECTK_JWT_KEY=replace-this-with-at-least-32-random-characters
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

# SQL Server requires a strong SA password.
PROJECTK_SQL_PASSWORD=Change_this_SQL_password_123!
PROJECTK_SQL_EDITION=Developer
PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoGSqFb3JhiGJwn7Q9DkzzJ65b9TqK4C8FYG4O3fM7w==;BlobEndpoint=http://projectk-azurite:10000/devstoreaccount1;QueueEndpoint=http://projectk-azurite:10001/devstoreaccount1;TableEndpoint=http://projectk-azurite:10002/devstoreaccount1;

# Required only when building images locally and restoring private GitHub NuGet packages.
PROJECTK_NUGET_AUTH_TOKEN=


