# Environment: tailscale (ASPNETCORE_ENVIRONMENT=Tailscale)
# LAN/Tailnet access. Override PROJECTK_API_URL / PROJECTK_CORS_ORIGIN with your
# Tailscale IP when sharing across devices; localhost defaults work on one host.
PROJECTK_ENV=tailscale
PROJECTK_ASPNETCORE_ENV=Tailscale
PROJECTK_NG_CONFIG=tailscale

PROJECTK_WEB_PORT=4210
PROJECTK_API_PORT=5225

# Replace localhost with your Tailscale IP (e.g. http://100.64.66.7:5225/api) to
# reach the stack from other devices on the tailnet.
PROJECTK_API_URL=http://localhost:5225/api
PROJECTK_PUBLIC_URL=http://localhost:4210
PROJECTK_CORS_ORIGIN=http://localhost:4210

PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK_tailscale;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoGSqFb3JhiGJwn7Q9DkzzJ65b9TqK4C8FYG4O3fM7w==;BlobEndpoint=http://projectk-azurite:10000/devstoreaccount1;QueueEndpoint=http://projectk-azurite:10001/devstoreaccount1;TableEndpoint=http://projectk-azurite:10002/devstoreaccount1;

PROJECTK_JWT_KEY=local-tailscale-jwt-key-change-me-please-at-least-32
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

PROJECTK_NUGET_AUTH_TOKEN=

PROJECTK_API_IMAGE=
PROJECTK_WEB_IMAGE=
