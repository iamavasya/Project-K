# Environment: dev (ASPNETCORE_ENVIRONMENT=Development)
# Local development against the shared SQL + Azurite tooling.
PROJECTK_ENV=dev
PROJECTK_ASPNETCORE_ENV=Development
PROJECTK_NG_CONFIG=development

# Host ports (unique per environment so several stacks can run at once).
PROJECTK_WEB_PORT=4200
PROJECTK_API_PORT=5205

# Frontend runtime API URL + backend CORS/public origin.
PROJECTK_API_URL=http://localhost:5205/api
PROJECTK_PUBLIC_URL=http://localhost:4200
PROJECTK_CORS_ORIGIN=http://localhost:4200

# Data lives on the shared projectk-sql server, in a per-environment database.
PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK_dev;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

# Shared Azurite blob storage (well-known Azurite default account).
PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoGSqFb3JhiGJwn7Q9DkzzJ65b9TqK4C8FYG4O3fM7w==;BlobEndpoint=http://projectk-azurite:10000/devstoreaccount1;QueueEndpoint=http://projectk-azurite:10001/devstoreaccount1;TableEndpoint=http://projectk-azurite:10002/devstoreaccount1;

# Dev-only secrets — safe defaults, change before exposing anything.
PROJECTK_JWT_KEY=local-development-jwt-key-change-me-please-32chars
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

# Set only when building the API image locally (private GitHub NuGet packages).
PROJECTK_NUGET_AUTH_TOKEN=

# To consume a prebuilt image instead of building locally, set these to a tag
# (e.g. ghcr.io/iamavasya/projectk-api:0.15.0-beta). Left blank => build locally.
PROJECTK_API_IMAGE=
PROJECTK_WEB_IMAGE=
