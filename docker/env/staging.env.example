# Environment: staging (ASPNETCORE_ENVIRONMENT=Staging)
#
# Copy to docker/env/staging.env (gitignored) and fill in real secrets before use.
# Two ways to run staging locally:
#   1. Config smoke test  — keep the local shared-tooling connection strings below
#                           to verify the Staging build boots against local SQL/Azurite.
#   2. Against cloud       — replace the connection strings + JWT with the real
#                           Azure Staging secrets to point at cloud infrastructure.
PROJECTK_ENV=staging
PROJECTK_ASPNETCORE_ENV=Staging
PROJECTK_NG_CONFIG=staging

PROJECTK_WEB_PORT=8090
PROJECTK_API_PORT=5235

PROJECTK_API_URL=http://localhost:5235/api
PROJECTK_ENVIRONMENT_NAME=Staging
PROJECTK_PUBLIC_URL=http://localhost:8090
PROJECTK_CORS_ORIGIN=http://localhost:8090

# Local shared-tooling defaults (config smoke test). Replace for cloud staging.
PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK_staging;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://projectk-azurite

# REQUIRED: set a real 32+ char secret.
PROJECTK_JWT_KEY=set-a-real-staging-jwt-key-at-least-32-characters
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

PROJECTK_NUGET_AUTH_TOKEN=

# Optional: point at a prebuilt image instead of building locally.
PROJECTK_API_IMAGE=
PROJECTK_WEB_IMAGE=
