# Environment: prod (ASPNETCORE_ENVIRONMENT=Production)
#
# Copy to docker/env/prod.env (gitignored) and fill in real secrets before use.
# Primarily for smoke-testing the Production build/config locally. Pointing at the
# real production database from a developer machine is discouraged — prefer the
# local shared tooling below and only swap secrets deliberately.
PROJECTK_ENV=prod
PROJECTK_ASPNETCORE_ENV=Production
PROJECTK_NG_CONFIG=production

PROJECTK_WEB_PORT=8095
PROJECTK_API_PORT=5245

PROJECTK_API_URL=http://localhost:5245/api
PROJECTK_PUBLIC_URL=http://localhost:8095
PROJECTK_CORS_ORIGIN=http://localhost:8095

# Local shared-tooling defaults (config smoke test). Replace only if you truly
# intend to point at real production infrastructure.
PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK_prod;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=http;AccountName=devstoreaccount1;AccountKey=Eby8vdM02xNoGSqFb3JhiGJwn7Q9DkzzJ65b9TqK4C8FYG4O3fM7w==;BlobEndpoint=http://projectk-azurite:10000/devstoreaccount1;QueueEndpoint=http://projectk-azurite:10001/devstoreaccount1;TableEndpoint=http://projectk-azurite:10002/devstoreaccount1;

# REQUIRED: set a real 32+ char secret.
PROJECTK_JWT_KEY=set-a-real-production-jwt-key-at-least-32-characters
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

PROJECTK_NUGET_AUTH_TOKEN=

PROJECTK_API_IMAGE=
PROJECTK_WEB_IMAGE=
