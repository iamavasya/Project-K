# Environment: selfhost (ASPNETCORE_ENVIRONMENT=SelfHost)
# Mirrors the self-host deployment: no admin seeded, first-run /setup flow,
# MFA enforcement off by default. Production Angular build.
PROJECTK_ENV=selfhost
PROJECTK_ASPNETCORE_ENV=SelfHost
PROJECTK_NG_CONFIG=production

PROJECTK_WEB_PORT=8080
PROJECTK_API_PORT=5215

PROJECTK_API_URL=http://localhost:5215/api
PROJECTK_ENVIRONMENT_NAME=Self-Host
PROJECTK_PUBLIC_URL=http://localhost:8080
PROJECTK_CORS_ORIGIN=http://localhost:8080

PROJECTK_DB_CONNECTION_STRING=Server=projectk-sql,1433;Database=projectK_selfhost;User Id=sa;Password=Change_this_SQL_password_123!;TrustServerCertificate=True;Encrypt=False;

PROJECTK_BLOB_CONTAINER=photos
PROJECTK_BLOB_PUBLIC_BASE_URL=http://localhost:10000/devstoreaccount1/photos
PROJECTK_BLOB_CONNECTION_STRING=UseDevelopmentStorage=true;DevelopmentStorageProxyUri=http://projectk-azurite

PROJECTK_JWT_KEY=local-selfhost-jwt-key-change-me-please-at-least-32
PROJECTK_JWT_ISSUER=ProjectK-Backend
PROJECTK_JWT_AUDIENCE=ProjectK-Users

# NuGet auth for building the API image is read from your HOST env var
# NUGET_AUTH_TOKEN. Do NOT put a token in this committed file. See docker/README.md.

PROJECTK_API_IMAGE=
PROJECTK_WEB_IMAGE=
